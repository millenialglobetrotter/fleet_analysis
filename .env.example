FLEET_CONFIG_FILE=./config.json
HOST=0.0.0.0
PORT=8000
FLEET_MAX_WORKERS=40

FLEET_AUTH_BASE_URL=https://ncvocj.condense.zeliot.in/vehicle-da-mgmt
FLEET_AUTH_ENDPOINT=/api/auth
FLEET_AUTH_CLIENT_ID=your-client-id
FLEET_AUTH_CLIENT_SECRET=replace-me

FLEET_VEHICLE_REGISTRY_BASE_URL=https://ncvocj.condense.zeliot.in/vehicle-da-mgmt
FLEET_VEHICLE_REGISTRY_ENDPOINT=/api/customers

FLEET_PREDICTION_SERVICE_BASE_URL=https://ncvocj.condense.zeliot.in/da-vehicle-functions-non-queue
FLEET_PREDICTION_SERVICE_URL_TEMPLATE=/api/predict-result/{id}?&from={from_date}&to={to_date}

FLEET_DECRYPTION_SERVICE_BASE_URL=https://mscd-dev-prog-da-pred-af.azurewebsites.net
FLEET_DECRYPTION_SERVICE_ENDPOINT=/api/decrypt
FLEET_DECRYPTION_SERVICE_CLIENT_ID=your-client-id
FLEET_DECRYPTION_SERVICE_CLIENT_SECRET=replace-me

FLEET_DB_HOST=localhost
FLEET_DB_PORT=3306
FLEET_DB_USER=fleet_user
FLEET_DB_PASSWORD=replace-me
FLEET_DB_NAME=fleet_analytics
